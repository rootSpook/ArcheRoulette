PORT=5000
MONGODB_URI=mongodb://localhost:27017/archeroulette
JWT_SECRET=change_this_secret
JWT_EXPIRES_IN=7d
FRONTEND_ORIGIN=http://localhost:3000

# Set to "true" only once the site is actually served over HTTPS. Leaving this
# false on an HTTP-only deployment is required — a Secure cookie is silently
# dropped by the browser on plain HTTP, which would break login.
COOKIE_SECURE=false

# 32-byte (64 hex char) key used to encrypt the Riot API key stored in MongoDB.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Legacy — only read once as a fallback to migrate an existing key into encrypted
# DB storage. Set the real key from the admin Ayarlar page instead.
RIOT_API_KEY=
